{
  "expo": {
    "name": "Smart Market Scanner",
    "slug": "smart-market-scanner",
    "scheme": "smartmarket",
    "plugins": ["expo-router", "expo-secure-store"],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "permissions": ["CAMERA", "VIBRATE"]
    },
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos da camera para ler codigos de barras dos produtos."
      }
    },
    "experiments": {
      "typedRoutes": false
    }
  }
}
